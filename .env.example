# ── Database ─────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (from neon.tech dashboard)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=10000

# ── Auth ──────────────────────────────────────────────────────────────────────
# Use strong random secrets — run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your Vercel frontend URL (no trailing slash)
FRONTEND_URL=https://v-trinity-solutions.vercel.app

# ── Email ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=info@v-trinitysolutions.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_MAX=20
